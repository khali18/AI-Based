{
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/login", "dest": "/api/login.py" },
    { "src": "/api/register", "dest": "/api/register.py" },
    { "src": "/api/dashboard", "dest": "/api/dashboard.py" },
    { "src": "/api/inventory", "dest": "/api/inventory.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
